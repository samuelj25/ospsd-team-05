# ---------------------------------------------------------------------------
# Copy this file to terraform.tfvars and fill in real values.
# terraform.tfvars is gitignored — NEVER commit it.
#
#   cp terraform.tfvars.example terraform.tfvars
# ---------------------------------------------------------------------------

# Render platform — get from teammate who owns the Render account
render_api_key    = "rnd_REPLACE_WITH_REAL_API_KEY"
render_owner_id   = "REPLACE_WITH_OWNER_ID"
render_service_id = "srv-REPLACE_WITH_REAL_SERVICE_ID"

# Google OAuth — get from GCP Console > APIs & Services > Credentials
google_oauth_client_id     = "REPLACE.apps.googleusercontent.com"
google_oauth_client_secret = "REPLACE_WITH_CLIENT_SECRET"
oauth_redirect_uri         = "https://ospsd-team-05.onrender.com/auth/callback"
google_calendar_id         = "primary"

# Session security — generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
session_secret = "REPLACE_WITH_LONG_RANDOM_HEX_STRING"

# GCP credentials for CI — base64-encoded JSON files
# Generate with: base64 -i credentials.json
gcp_credentials_json_base64 = "REPLACE_WITH_BASE64_CREDENTIALS_JSON"
gcp_token_json_base64       = "REPLACE_WITH_BASE64_TOKEN_JSON"

# Get from aistudio.google.com > Get API Key
gemini_api_key = "AIza-REPLACE_WITH_REAL_GEMINI_KEY"

slack_bot_token    = "xoxb-REPLACE"